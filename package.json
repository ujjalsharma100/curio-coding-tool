{
  "name": "curio-code",
  "version": "0.0.0",
  "description": "Curio Code — a terminal-based AI coding assistant built on the Curio Agent SDK (TypeScript).",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile=curio-code --external electron --external playwright --external playwright-core --external chromium-bidi/lib/cjs/bidiMapper/BidiMapper --external chromium-bidi/lib/cjs/cdp/CdpConnection",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "changeset": "changeset",
    "release": "changeset version && changeset publish"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "curio-agent-sdk": "link:../curio-agent-sdk-typescript",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.8",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.11",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.4"
  }
}
